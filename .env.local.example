# Supabase — investor request form storage.
# Copy to .env.local and fill in from the Supabase dashboard
# (Project Settings → API). The anon/publishable key is safe to use here:
# row level security only allows inserts into investor_requests.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
